---
import Layout from '../layouts/Layout.astro';
import DrakyHero from '../components/DrakyHero';
import ThemeToggle from '../components/ThemeToggle';
import { Download, Star, ExternalLink, Heart, CheckCircle2, Github } from 'lucide-react';
---

<Layout title="Draction - Your cute little desktop companion">
  <!-- Navbar -->
  <nav class="flex items-center justify-between p-6 md:px-12 max-w-7xl mx-auto w-full relative z-50">
    <div class="flex items-center gap-3">
      <span class="font-black text-3xl tracking-tighter text-slate-800 dark:text-slate-100"><span class="text-turquoise-500">Dra</span>ction</span>
    </div>
    <div class="flex items-center gap-4 sm:gap-6 font-semibold text-slate-600 dark:text-slate-300 bg-white/50 dark:bg-slate-800/50 backdrop-blur-md px-6 py-3 rounded-full shadow-sm ring-1 ring-turquoise-100 dark:ring-slate-700 transition-colors duration-300">
      <a href="#features" class="hover:text-turquoise-500 dark:hover:text-turquoise-400 transition-colors hidden sm:block">Features</a>
      <a href="https://github.com/draction" target="_blank" class="hover:text-turquoise-500 dark:hover:text-turquoise-400 transition-colors flex items-center gap-2">
        <Github size={18} class="fill-current" /> <span class="hidden sm:inline">GitHub</span>
      </a>
      <div class="w-px h-5 bg-slate-200 dark:bg-slate-700"></div>
      <ThemeToggle client:load />
    </div>
  </nav>

  <!-- Hero Section -->
  <main class="flex-1 flex flex-col items-center justify-center -mt-12">
    <div class="max-w-7xl mx-auto w-full grid grid-cols-1 lg:grid-cols-2 gap-12 items-center p-6 md:p-12 relative">
      
      <!-- Text Area -->
      <div class="flex flex-col gap-8 order-2 lg:order-1 text-center lg:text-left z-10">
        <div class="inline-flex items-center gap-2 bg-pink-100 dark:bg-pink-900/40 text-pink-600 dark:text-pink-300 px-4 py-2 rounded-full font-bold text-sm w-fit mx-auto lg:mx-0 shadow-sm transition-colors duration-300">
          <Heart size={16} class="fill-current" />
          Say hello to Draky!
        </div>
        
        <h1 class="text-5xl md:text-7xl font-black text-slate-800 dark:text-slate-100 leading-[1.1] tracking-tight drop-shadow-sm transition-colors duration-300">
          A <span class="text-transparent bg-clip-text bg-gradient-to-r from-turquoise-500 to-sky-400">cute</span> dragon <br/> on your desktop
        </h1>
        
        <p class="text-lg md:text-xl text-slate-600 dark:text-slate-300 font-medium max-w-lg mx-auto lg:mx-0 leading-relaxed transition-colors duration-300">
          Draction is an always-on-top, transparent companion that eats your files and organizes them. 
          Just drag, drop, and watch Draky do the magic! ✨
        </p>

        <div class="flex flex-col sm:flex-row items-center gap-4 mt-4 mx-auto lg:mx-0">
          <button class="bg-turquoise-500 hover:bg-turquoise-400 text-white font-bold text-lg px-8 py-4 rounded-3xl shadow-[0_8px_0_0_#0d9488] dark:shadow-[0_8px_0_0_#0f766e] hover:shadow-[0_4px_0_0_#0d9488] dark:hover:shadow-[0_4px_0_0_#0f766e] hover:translate-y-1 transition-all flex items-center gap-3">
            <Download size={24} />
            Download for macOS
          </button>
          <a href="#how-it-works" class="text-slate-500 dark:text-slate-400 font-bold hover:text-turquoise-500 dark:hover:text-turquoise-400 px-6 py-4 flex items-center gap-2 transition-colors">
            See how it works 
          </a>
        </div>
      </div>

      <!-- Mascot Area -->
      <div class="order-1 lg:order-2 flex items-center justify-center relative">
        <DrakyHero client:load />
      </div>
      
    </div>
  </main>

  <!-- Features Strip -->
  <section class="relative z-10 w-full bg-white/60 dark:bg-slate-900/60 backdrop-blur-lg border-y border-turquoise-100 dark:border-slate-800 py-16 transition-colors duration-300" id="features">
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-12 text-center">
      <div class="flex flex-col items-center gap-4">
        <div class="bg-sky-100 dark:bg-sky-900/50 text-sky-500 dark:text-sky-400 p-4 rounded-3xl w-20 h-20 flex items-center justify-center transform rotate-3 shadow-sm transition-colors duration-300">
           <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg>
        </div>
        <h3 class="text-2xl font-bold text-slate-800 dark:text-slate-100 transition-colors duration-300">Always on Top</h3>
        <p class="text-slate-600 dark:text-slate-400 font-medium transition-colors duration-300">Float Draky over all your windows. He's always ready to help you manage your files anytime.</p>
      </div>

      <div class="flex flex-col items-center gap-4">
        <div class="bg-turquoise-100 dark:bg-turquoise-900/50 text-turquoise-500 dark:text-turquoise-400 p-4 rounded-3xl w-20 h-20 flex items-center justify-center transform -rotate-3 shadow-sm transition-colors duration-300">
           <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
        </div>
        <h3 class="text-2xl font-bold text-slate-800 dark:text-slate-100 transition-colors duration-300">Drag & Drop</h3>
        <p class="text-slate-600 dark:text-slate-400 font-medium transition-colors duration-300">Just drop anything into his mouth! He eats files or text directly off your screen seamlessly.</p>
      </div>

      <div class="flex flex-col items-center gap-4">
        <div class="bg-pink-100 dark:bg-pink-900/50 text-pink-500 dark:text-pink-400 p-4 rounded-3xl w-20 h-20 flex items-center justify-center transform rotate-3 shadow-sm transition-colors duration-300">
           <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        </div>
        <h3 class="text-2xl font-bold text-slate-800 dark:text-slate-100 transition-colors duration-300">Aesthetically Cute</h3>
        <p class="text-slate-600 dark:text-slate-400 font-medium transition-colors duration-300">Say goodbye to boring utilities. Draction brings a pixel-perfect, high-resolution aesthetic friend to your desktop.</p>
      </div>
    </div>
  </section>

  <!-- How it Works Section -->
  <section class="max-w-5xl mx-auto px-6 py-24" id="how-it-works">
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 bg-purple-100 dark:bg-purple-900/40 text-purple-600 dark:text-purple-300 px-4 py-2 rounded-full font-bold text-sm mb-4 shadow-sm transition-colors duration-300">
        <Star size={16} class="fill-current" />
        So Simple
      </div>
      <h2 class="text-4xl md:text-5xl font-black text-slate-800 dark:text-slate-100 transition-colors duration-300">How it works</h2>
      <p class="text-slate-600 dark:text-slate-400 font-medium mt-4 text-lg transition-colors duration-300">Three easy steps to a magical workflow.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 relative">
      <!-- Decorative path connecting steps (visible on md+) -->
      <div class="hidden md:block absolute top-[120px] left-[15%] right-[15%] h-1 border-t-4 border-dashed border-turquoise-200 dark:border-slate-700 z-0 transition-colors duration-300"></div>

      <!-- Step 1 -->
      <div class="flex flex-col items-center text-center relative z-10 group">
        <div class="w-16 h-16 rounded-full bg-turquoise-100 dark:bg-turquoise-900/50 text-turquoise-600 dark:text-turquoise-400 font-black text-2xl flex items-center justify-center mb-6 shadow-sm ring-4 ring-white dark:ring-slate-900 transition-all duration-300 group-hover:scale-110">1</div>
        <div class="bg-white dark:bg-slate-800 rounded-3xl p-8 shadow-sm dark:shadow-none border border-slate-100 dark:border-slate-700 w-full hover:shadow-md transition-all duration-300">
          <h3 class="font-bold text-xl text-slate-800 dark:text-slate-100 mb-2">Find a file</h3>
          <p class="text-slate-600 dark:text-slate-400">Grab any file, image, or selected text you want to organize or process.</p>
        </div>
      </div>

      <!-- Step 2 -->
      <div class="flex flex-col items-center text-center relative z-10 group mt-0 md:mt-12">
        <div class="w-16 h-16 rounded-full bg-pink-100 dark:bg-pink-900/50 text-pink-500 dark:text-pink-400 font-black text-2xl flex items-center justify-center mb-6 shadow-sm ring-4 ring-white dark:ring-slate-900 transition-all duration-300 group-hover:scale-110">2</div>
        <div class="bg-white dark:bg-slate-800 rounded-3xl p-8 shadow-sm dark:shadow-none border border-slate-100 dark:border-slate-700 w-full hover:shadow-md transition-all duration-300">
          <h3 class="font-bold text-xl text-slate-800 dark:text-slate-100 mb-2">Drag to Draky</h3>
          <p class="text-slate-600 dark:text-slate-400">Drag it straight to your cute desktop companion. He'll open wide!</p>
        </div>
      </div>

      <!-- Step 3 -->
      <div class="flex flex-col items-center text-center relative z-10 group">
        <div class="w-16 h-16 rounded-full bg-sky-100 dark:bg-sky-900/50 text-sky-500 dark:text-sky-400 font-black text-2xl flex items-center justify-center mb-6 shadow-sm ring-4 ring-white dark:ring-slate-900 transition-all duration-300 group-hover:scale-110">3</div>
        <div class="bg-white dark:bg-slate-800 rounded-3xl p-8 shadow-sm dark:shadow-none border border-slate-100 dark:border-slate-700 w-full hover:shadow-md transition-all duration-300">
          <h3 class="font-bold text-xl text-slate-800 dark:text-slate-100 mb-2">Done!</h3>
          <p class="text-slate-600 dark:text-slate-400">Draky eats the file and automatically hands it over to your workflow pipeline.</p>
        </div>
      </div>
    </div>
  </section>
  
  <footer class="text-center py-12 text-slate-500 dark:text-slate-500 font-medium">
    <p>Made with ❤️ by the Draction Team.</p>
  </footer>
</Layout>
